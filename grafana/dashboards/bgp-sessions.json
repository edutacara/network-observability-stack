{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "Session Overview",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            { "options": { "1": { "color": "red",    "text": "Idle" },
                           "2": { "color": "orange", "text": "Connect" },
                           "3": { "color": "orange", "text": "Active" },
                           "4": { "color": "yellow", "text": "OpenSent" },
                           "5": { "color": "yellow", "text": "OpenConfirm" },
                           "6": { "color": "green",  "text": "Established" } },
              "type": "value" }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",   "value": null },
              { "color": "green", "value": 6 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name"
      },
      "pluginVersion": "11.1.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "bgpPeerState",
          "instant": true,
          "legendFormat": "{{instance}} → {{bgpPeerRemoteAddr}}",
          "refId": "A"
        }
      ],
      "title": "BGP Peer State",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",   "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "id": 3,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name"
      },
      "pluginVersion": "11.1.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "bgpPeerFsmEstablishedTransitions",
          "instant": true,
          "legendFormat": "{{instance}} → {{bgpPeerRemoteAddr}}",
          "refId": "A"
        }
      ],
      "title": "Session Flaps (total)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [ { "color": "blue", "value": null } ]
          },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "id": 4,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name"
      },
      "pluginVersion": "11.1.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "bgpPeerFsmEstablishedTime",
          "instant": true,
          "legendFormat": "{{instance}} → {{bgpPeerRemoteAddr}}",
          "refId": "A"
        }
      ],
      "title": "Session Uptime",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "inspect": false
          },
          "mappings": [
            { "options": { "1": { "text": "Idle" },
                           "2": { "text": "Connect" },
                           "3": { "text": "Active" },
                           "4": { "text": "OpenSent" },
                           "5": { "text": "OpenConfirm" },
                           "6": { "text": "Established" } },
              "type": "value" }
          ]
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "State" },
            "properties": [
              { "id": "custom.cellOptions", "value": { "type": "color-text" } },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [
                  { "color": "red", "value": null },
                  { "color": "green", "value": 6 }
              ] } },
              { "id": "color", "value": { "mode": "thresholds" } }
            ]
          }
        ]
      },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 5 },
      "id": 5,
      "options": {
        "cellHeight": "sm",
        "footer": { "countRows": false, "fields": "", "reducer": ["sum"], "show": false },
        "showHeader": true
      },
      "pluginVersion": "11.1.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "bgpPeerState",
          "instant": true,
          "legendFormat": "{{instance}}",
          "refId": "state"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "bgpPeerRemoteAs",
          "instant": true,
          "legendFormat": "{{instance}}",
          "refId": "remoteas"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "bgpPeerFsmEstablishedTime",
          "instant": true,
          "legendFormat": "{{instance}}",
          "refId": "uptime"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "bgpPeerFsmEstablishedTransitions",
          "instant": true,
          "legendFormat": "{{instance}}",
          "refId": "flaps"
        }
      ],
      "title": "BGP Peer Table",
      "transformations": [
        { "id": "labelsToFields", "options": { "mode": "columns", "valueLabel": "bgpPeerRemoteAddr" } },
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "instance": "Router",
              "bgpPeerRemoteAddr": "Peer IP",
              "Value #state": "State",
              "Value #remoteas": "Remote AS",
              "Value #uptime": "Uptime (s)",
              "Value #flaps": "Flaps"
            }
          }
        }
      ],
      "type": "table"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 11 },
      "id": 10,
      "title": "Message Rates",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisLabel": "msg/s",
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": true
          },
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "id": 6,
      "options": {
        "legend": { "calcs": ["mean", "lastNotNull"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(bgpPeerInTotalMessages[5m])",
          "legendFormat": "{{instance}} ← {{bgpPeerRemoteAddr}} in",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(bgpPeerOutTotalMessages[5m])",
          "legendFormat": "{{instance}} → {{bgpPeerRemoteAddr}} out",
          "refId": "B"
        }
      ],
      "title": "BGP Messages In/Out (rate)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisLabel": "updates/s",
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": true
          },
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "id": 7,
      "options": {
        "legend": { "calcs": ["mean", "lastNotNull"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(bgpPeerInUpdates[5m])",
          "legendFormat": "{{instance}} ← {{bgpPeerRemoteAddr}} in",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(bgpPeerOutUpdates[5m])",
          "legendFormat": "{{instance}} → {{bgpPeerRemoteAddr}} out",
          "refId": "B"
        }
      ],
      "title": "BGP Updates In/Out (rate)",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["network", "bgp", "snmp"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Network / BGP Sessions (SNMP)",
  "uid": "network-bgp-sessions",
  "version": 1
}
